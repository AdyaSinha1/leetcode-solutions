//code 2
class Solution {
    public int[] plusOne(int[] digits) {
        // Traverse the array from the last digit backwards
        for (int i = digits.length - 1; i >= 0; i--) {
            // Case 1: If current digit is less than 9, just increment it
            if (digits[i] < 9) {
                digits[i]++;       // add one
                return digits;     // no carry needed, return immediately
            }
            // Case 2: If current digit is 9, set it to 0 and carry over
            digits[i] = 0;
        }

        // Case 3: If we finish the loop, it means all digits were 9
        // Example: [9,9,9] → [0,0,0] → need new array [1,0,0,0]
        int[] result = new int[digits.length + 1];
        result[0] = 1;  // first digit becomes 1, rest default to 0
        return result;
    }
}

