class Solution {
    public int search(int[] nums, int target) {
        int l = 0;                      // Left boundary of search
        int r = nums.length - 1;        // Right boundary of search

        // Standard binary search loop
        while (l <= r) {
            int m = l + (r - l) / 2;    // Midpoint to avoid overflow

            //  If target found at mid, return index
            if (nums[m] == target) {
                return m;
            }

            // Check if the left half [l..m] is sorted
            if (nums[l] <= nums[m]) {
                // If target lies within the sorted left half
                if (nums[l] <= target && target < nums[m]) {
                    r = m - 1;          // Narrow search to left half
                } else {
                    l = m + 1;          // Otherwise, search right half
                }
            }
            // Else, the right half [m..r] must be sorted
            else {
                // If target lies within the sorted right half
                if (nums[m] < target && target <= nums[r]) {
                    l = m + 1;          // Narrow search to right half
                } else {
                    r = m - 1;          // Otherwise, search left half
                }
            }
        }

        // Target not found
        return -1;
    }
}


\\ Time complexity: O(log n) (same as binary search).

\\ Space complexity: O(1).
